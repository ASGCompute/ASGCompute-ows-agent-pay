# Stripe MPP Integration — Environment Variables
# Copy to .env and fill with your actual keys (NEVER commit .env)

# Stripe keys (get from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_live_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_live_your_key_here

# Stripe account details
STRIPE_ACCOUNT_ID=acct_your_id_here
STRIPE_NETWORK_ID=acct_your_id_here
